# ══════════════════════════════════════════════════════
#  AI Life Manager — .gitignore
# ══════════════════════════════════════════════════════

# ── Environment & Secrets ─────────────────────────────
.env
.env.local
.env.production
.env.staging
*.env
firebase-credentials.json
*-credentials.json
*-service-account.json

# ── Python ────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.pyc

# ── Virtual Environment ───────────────────────────────
venv/
env/
ENV/
.venv/
.env/
venv.bak/

# ── Package / Build ───────────────────────────────────
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
pip-wheel-metadata/
share/python-wheels/
MANIFEST

# ── Testing ───────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
nosetests.xml
test-results/

# ── Alembic ───────────────────────────────────────────
# Keep alembic.ini and versions/ but ignore autogenerated temp files
alembic/versions/*.pyc

# ── IDE & Editors ─────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Docker ────────────────────────────────────────────
# Keep docker-compose.yml but ignore override files
docker-compose.override.yml
docker-compose.local.yml

# ── Logs ──────────────────────────────────────────────
*.log
logs/
log/

# ── Database ──────────────────────────────────────────
*.sqlite3
*.db
*.sql.bak
postgres_data/
redis_data/

# ── OS ────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Misc ──────────────────────────────────────────────
.cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
*.bak
*.tmp
*.temp
